{
  "name": "claude-everywhere",
  "version": "0.1.0",
  "description": "Connect Claude to anything — browser extension + MCP servers for Gmail, Discord, Replit, and more.",
  "private": true,
  "workspaces": [
    "mcp-servers/*",
    "extension"
